StructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260325081851KJNPOZ</odePageId><odeBlockId>20260325081851OMGUAH</odeBlockId><odeIdeviceId>20260324233701829UZH</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p&gt;Las herramientas de comunicación que utilizaré serán las siguientes:&lt;/p&gt;
&lt;p&gt;&lt;em&gt;Comunicación entre los docentes:&lt;/em&gt;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Correo corporativo de Séneca: &lt;/strong&gt;donde el equipo directivo enviará información relevante acerca de reuniones, normativa, organización...&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Google Drive:&lt;/strong&gt; donde podremos compartir información y es ideal para el trabajo colaborativo de cara a las evaluaciones, datos a aportar en tutorías…&lt;br&gt;&amp;nbsp;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;em&gt;Comunicación entre el profesorado y el alumnado:&lt;/em&gt;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Google Classroom: &lt;/strong&gt;es fácil de usar e incorpora métodos de comunicación en tiempo real entre docentes y alumnado. Además, permite crear y gestionar clases, así como plantear preguntas, habilitar tablón de anuncios... Lo utilizaremos para colgar el material, proponer tareas, pequeños debates ...&lt;br&gt;&amp;nbsp;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;em&gt;Comunicación entre el profesorado y la familia:&lt;/em&gt;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;iPasen o PASEN &lt;/strong&gt;(aplicación que ha desarrollado la Consejería de Educación para la gestión de centros docentes), es una opción eficaz y muy empleada en todos los centros, donde la comunicación es directa con las familias y queda reflejada. Se enviarán notas informativas, citaciones, autorizaciones, calificaciones...&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Google Classroom:&lt;/strong&gt; donde podrán comprobar las tareas dadas en clase, las enviadas para hacer en casa, futuros proyectos, trabajos...&lt;/li&gt;
&lt;/ul&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260324233701829UZH","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;Las herramientas de comunicación que utilizaré serán las siguientes:&lt;/p&gt;\n&lt;p&gt;&lt;em&gt;Comunicación entre los docentes:&lt;/em&gt;&lt;/p&gt;\n&lt;ul&gt;\n&lt;li&gt;&lt;strong&gt;Correo corporativo de Séneca: &lt;/strong&gt;donde el equipo directivo enviará información relevante acerca de reuniones, normativa, organización...&lt;/li&gt;\n&lt;li&gt;&lt;strong&gt;Google Drive:&lt;/strong&gt; donde podremos compartir información y es ideal para el trabajo colaborativo de cara a las evaluaciones, datos a aportar en tutorías…&lt;br /&gt; &lt;/li&gt;\n&lt;/ul&gt;\n&lt;p&gt;&lt;em&gt;Comunicación entre el profesorado y el alumnado:&lt;/em&gt;&lt;/p&gt;\n&lt;ul&gt;\n&lt;li&gt;&lt;strong&gt;Google Classroom: &lt;/strong&gt;es fácil de usar e incorpora métodos de comunicación en tiempo real entre docentes y alumnado. Además, permite crear y gestionar clases, así como plantear preguntas, habilitar tablón de anuncios... Lo utilizaremos para colgar el material, proponer tareas, pequeños debates ...&lt;br /&gt; &lt;/li&gt;\n&lt;/ul&gt;\n&lt;p&gt;&lt;em&gt;Comunicación entre el profesorado y la familia:&lt;/em&gt;&lt;/p&gt;\n&lt;ul&gt;\n&lt;li&gt;&lt;strong&gt;iPasen o PASEN &lt;/strong&gt;(aplicación que ha desarrollado la Consejería de Educación para la gestión de centros docentes), es una opción eficaz y muy empleada en todos los centros, donde la comunicación es directa con las familias y queda reflejada. Se enviarán notas informativas, citaciones, autorizaciones, calificaciones...&lt;/li&gt;\n&lt;li&gt;&lt;strong&gt;Google Classroom:&lt;/strong&gt; donde podrán comprobar las tareas dadas en clase, las enviadas para hacer en casa, futuros proyectos, trabajos...&lt;/li&gt;\n&lt;/ul&gt;","text